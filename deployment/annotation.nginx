server {
        # Annotation Studio (static SPA) + Engine reverse proxy
        server_name annotation.edirepository.org;
        merge_slashes off;

        # Serve the built Studio (publish step copies studio/dist -> /var/www/annotation)
        root /var/www/annotation;
        index index.html;

        # Allow larger uploads if needed (EML files, etc.)
        client_max_body_size 512m;

        # React SPA routing: serve index.html for non-file paths
        location / {
                gzip on;
                gzip_buffers 8 256k;
                try_files $uri $uri/ /index.html;
        }

        # Proxy API requests to Engine (FastAPI on localhost:8000).
        #
        # IMPORTANT: the trailing slash on proxy_pass strips the /api/ prefix.
        #   /api/documents/targets -> http://127.0.0.1:8000/documents/targets
        location /api/ {
                gzip on;
                gzip_buffers 8 256k;

                proxy_pass http://127.0.0.1:8000/;
                proxy_http_version 1.1;

                proxy_set_header Host $host;
                proxy_set_header X-Real-IP $remote_addr;
                proxy_set_header X-Forwarded-Protocol $scheme;
                proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

                proxy_buffering off;
                proxy_buffer_size 8k;
                proxy_max_temp_file_size 0;

                proxy_set_header Connection "";
                proxy_connect_timeout       2100;
                proxy_send_timeout          2100;
                proxy_read_timeout          2100;
                send_timeout                2100;
        }
}